# ============================================================================
# VaakFlow backend environment.
# Copy to `.env` and fill in keys to switch a provider from MOCK -> REAL.
# Leave a key blank and that subsystem stays in deterministic MOCK mode.
# The app runs fully end-to-end with ZERO keys. Add keys to light up real ones.
# Verify what's live any time:  curl localhost:8000/health  (see "providers").
# Set FORCE_MOCK=1 to force mocks even when keys are present.
# Every key below is FREE and needs NO credit card. See docs/real-apis.md.
# ============================================================================

FORCE_MOCK=0
# Set DEMO_SEED=0 to start with an empty store (no demo work orders backfilled).
DEMO_SEED=0

# ============================================================================
# TIER 1 — Groq  (HIGHEST IMPACT: real LLM + real speech-to-text in one key)
#   Unlocks: Llama-3.3-70B reasoning/responses  AND  Whisper STT (voice in).
#   Get it: https://console.groq.com  ->  sign in  ->  "API Keys" (left nav)
#           ->  "Create API Key"  ->  copy the gsk_... value below.
# ============================================================================
GROQ_API_KEY=

# ============================================================================
# TIER 2 — Embeddings  (real semantic RAG retrieval). Pick EITHER provider.
#   EMBEDDINGS_PROVIDER below chooses: auto | gemini | nim | mock
#   "auto" = gemini if GEMINI_API_KEY set, else nim if NVIDIA key set, else mock.
# ----------------------------------------------------------------------------
# Option A — Google Gemini  (also enables multimodal / long-context LLM):
#   Get it: https://aistudio.google.com/apikey  ->  "Create API key"
#           ->  copy the AIza... value below.
GEMINI_API_KEY=
#
# Option B — NVIDIA NIM  (nv-embedqa-e5-v5, 1024-d — friend's choice):
#   Get it: https://build.nvidia.com  ->  sign in  ->  pick an embedding model
#           ->  "Get API Key" / "Generate API Key"  ->  copy the nvapi-... value.
NVIDIA_NIM_API_KEY=
#
# Force a specific embeddings backend (default "auto"):
EMBEDDINGS_PROVIDER=auto

# ============================================================================
# TIER 3 — Supabase  (real work-order persistence + realtime, instead of memory)
#   Get it: https://supabase.com/dashboard  ->  create a project  ->  wait for
#           it to provision  ->  Project Settings  ->  API.
#   Copy "Project URL"          -> SUPABASE_URL
#   Copy the "service_role" key -> SUPABASE_KEY  (secret; NOT the anon key)
#   First time: run the schema in the SQL Editor (see docs/real-apis.md / schema.sql).
# ============================================================================
SUPABASE_URL=
SUPABASE_KEY=

# ============================================================================
# TIER 4 — Neo4j AuraDB Free  (real knowledge graph instead of mock memory)
#   Get it: https://console.neo4j.io  ->  "New Instance"  ->  AuraDB Free
#           ->  on creation, DOWNLOAD/COPY the generated password (shown once!).
#   Copy the connection URI (neo4j+s://xxxx.databases.neo4j.io) -> NEO4J_URI
#   Username is "neo4j" by default. Paste the saved password -> NEO4J_PASSWORD.
#   Then seed the graph:  PYTHONPATH=. python ../scripts/seed_neo4j.py
# ============================================================================
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ============================================================================
# CORS (frontend origins, comma-separated; * for dev)
# ============================================================================
CORS_ORIGINS=*
